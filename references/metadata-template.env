# Copy this file to a temporary location, fill it, then run:
# scripts/generate_with_suno.sh --meta-file /path/to/filled.env
# Default output: ~/Documents/Suno/$TITLE/

TITLE="Song Title"
STYLE_DESCRIPTION="alternative-rock, male-vocals, acoustic-guitar, fast-tempo, dreamy"
EXCLUDE_STYLES="mainstream-pop, auto-tune, overly-happy"
LYRICS_FILE="/absolute/path/to/lyrics.txt"
MODEL="v5.5"
VOCAL=""
SUNO_USE_CAPTCHA_SOLVER="0"
# HCAPTCHA_TOKEN=""
